# DealSim IC Room Audit Configuration
# For high-stakes institutional pressure-testing, use high-reasoning models (GPT-4o or Qwen-Plus)

# Core LLM Configuration (OpenAI SDK Compatible)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# Zep Cloud Configuration (For GraphRAG and Temporal Memory)
# Get your key at https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# Project Metadata
PROJECT_NAME=DealSim
MANDATE="Institutional Deal Pressure-Testing"
UPLOAD_FOLDER=./uploads
RUN_STATE_DIR=./runs
LOG_LEVEL=INFO